      "bare": "bare-events",
      "default": "events"
    }
  },
  "dependencies": {
    "b4a": "^1.6.7",
    "bare-events": "^2.8.3",
    "hypercore": "^11.32.0",
    "hypercore-crypto": "^3.4.2",
    "hypercore-errors": "^1.4.0",
    "hypercore-id-encoding": "^1.3.0",
    "ready-resource": "^1.1.1",
    "sodium-universal": "^5.0.1",
